---
export interface Service {
  icon: string;
  title: string;
  description: string;
  items: string[];
  contactText?: string;
}

export interface Props {
  title?: string;
  subtitle?: string;
  services?: Service[];
}

const {
  title = "Nuestros Servicios",
  subtitle = "Calibración Certificada",
  services = [
    {
      icon: "weight",
      title: "Laboratorio de Masa",
      description: "Calibración de equipos e instrumentos de la magnitud de masa con patrones certificados.",
      items: [
        "Balanzas clase I, II, III",
        "Pesas M1, M2, M3",
        "Pesas desde 1g hasta 1000kg",
        "Básculas industriales"
      ],
      contactText: "Solicitar calibración de masa"
    },
    {
      icon: "flask",
      title: "Laboratorio de Volumen",
      description: "Servicios de calibración para instrumentos de medición volumétrica.",
      items: [
        "Medidores volumétricos",
        "Pipetas y buretas",
        "Probetas graduadas",
        "Cubicación de tanques"
      ],
      contactText: "Solicitar calibración de volumen"
    },
    {
      icon: "thermometer",
      title: "Laboratorio de Temperatura",
      description: "Calibración de equipos de medición de temperatura para procesos industriales.",
      items: [
        "Termómetros digitales y de vidrio",
        "Termohigrómetros",
        "Cámaras climáticas",
        "Hornos y estufas"
      ]
    }
  ]
} = Astro.props;
---

<section class="py-16 sm:py-24 bg-white">
  <div class="container mx-auto px-5 max-w-7xl">
    {/* Encabezado */}
    <div class="text-center mb-12 md:mb-16">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        {title} <span class="text-[#31A4EA]">{subtitle}</span>
      </h2>
    </div>

    {/* Grid de servicios */}
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map((service, index) => (
        <div 
          class="bg-gray-50 rounded-xl overflow-hidden hover:shadow-lg transition-all duration-300 border border-gray-100"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          {/* Icono del servicio */}
          <div class="p-6 bg-[#31A4EA] text-white">
            {service.icon === "weight" && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
              </svg>
            )}
            {service.icon === "flask" && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
              </svg>
            )}
            {service.icon === "thermometer" && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            )}
            <h3 class="text-xl font-semibold mt-4">{service.title}</h3>
          </div>

          {/* Contenido del servicio */}
          <div class="p-6">
            <p class="text-gray-600 mb-4">{service.description}</p>
            
            <h4 class="font-medium text-gray-900 mb-2">Equipos que calibramos:</h4>
            <ul class="space-y-2 mb-6">
              {service.items.map((item) => (
                <li class="flex items-start">
                  <svg class="h-5 w-5 text-[#31A4EA] mr-2 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-gray-600">{item}</span>
                </li>
              ))}
            </ul>

            {service.contactText && (
              <a 
                href="/contact" 
                class="inline-flex items-center text-blue-600 font-medium hover:text-blue-800 transition-colors"
              >
                {service.contactText}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>