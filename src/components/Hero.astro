---
import Button from '../components/Button.astro';
import Star from '../icons/Star.astro';
import Certificate from '../icons/Certificate.astro';
import Team from '../icons/Team.astro';

// Props configurables
export interface Props {
  badgeText?: string;
  highlightText?: string;
  title: string;
  titleHighlight?: string;
  description: string;
  ctaText?: string;
  ctaLink?: string;
  features?: Array<{
    icon?: string;
    text: string;
  }>;
}

const {
  badgeText = "Laboratorio acreditado",
  highlightText = "Norma NTP ISO/IEC 17025",
  title = "Precisión metrológica",
  titleHighlight = "certificada",
  description = "Más de 10 años garantizando la exactitud en calibración de equipos de medición industrial con trazabilidad internacional.",
  features = [
    { icon: "star", text: "10+ años de experiencia" },
    { icon: "certificate", text: "Patrones certificados" },
    { icon: "team", text: "Equipo técnico especializado" }
  ]
} = Astro.props;
---
<div class="mx-auto container max-w-6xl pt-14 md:pt-20 pb-16 px-5 flex flex-col items-center">
  <p class="mb-6 py-2 px-3.5 bg-blue-50 rounded-xl text-xs sm:text-sm tracking-tight text-[#31A4EA] hero-animate">
    {badgeText}. <span class="font-medium">{highlightText}</span>
  </p>

  <h1 class="mb-6 text-4xl sm:text-5xl md:text-6xl leading-[1.2] tracking-tight font-semibold text-center text-gray-900 hero-animate">
    {title} <br>
    {titleHighlight && (
      <span class="text-[#31A4EA]">{titleHighlight}</span>
    )}
  </h1>

  <p class="max-w-[580px] text-sm sm:text-base leading-relaxed tracking-tight text-center text-gray-600 hero-animate">
    {description}
  </p>

  <div class="my-7 flex flex-wrap justify-center items-center gap-y-4 gap-x-6 sm:gap-x-8 hero-animate">
    {features.map((feature) => (
      <p class="flex items-center gap-2 sm:gap-3 text-xs sm:text-sm font-medium tracking-tight text-gray-700">
        {feature.icon === "star" && <Star />}
        {feature.icon === "certificate" && <Certificate />}
        {feature.icon === "team" && <Team />}
        {feature.text}
      </p>
    ))}
  </div>

  <div class="hero-animate">
    <Button text='Solicita una cotización' href='/contact' />
  </div>
</div>
