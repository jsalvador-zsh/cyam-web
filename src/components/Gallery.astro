---
import { Image } from 'astro:assets';
import image1 from '../assets/gallery/image-1.png';
import image2 from '../assets/gallery/image-2.png';
import image3 from '../assets/gallery/image-3.png';
import image4 from '../assets/gallery/image-4.png';
import image5 from '../assets/gallery/image-5.png';
import image6 from '../assets/gallery/image-6.png';
import image7 from '../assets/gallery/image-7.png';
import image8 from '../assets/gallery/image-8.png';

export interface GalleryItem {
  image: ImageMetadata;
  alt: string;
  title?: string;
  description?: string;
  category?: string;
}

export interface Props {
  title?: string;
  subtitle?: string;
  introText?: string;
}

const { 
  title = "Donde la precisión se encuentra con la", 
  subtitle = "excelencia",
  introText = "En CYAM, cada rincón de nuestro laboratorio está diseñado para garantizar la máxima exactitud en nuestros procesos de calibración. Conoce nuestras instalaciones y equipos de última generación."
} = Astro.props;

const galleryItems: GalleryItem[] = [
  {
    image: image1,
    alt: "Vista panorámica del laboratorio de masa",
    title: "Laboratorio de Masa",
    description: "Equipado con patrones certificados por INACAL para garantizar trazabilidad metrológica.",
    category: "Infraestructura"
  },
  {
    image: image2,
    alt: "Detalle de balanzas analíticas de alta precisión",
    title: "Precisión Microscópica",
    description: "Balanzas clase I con resolución de 0.1mg para los requerimientos más exigentes.",
    category: "Equipos"
  },
  {
    image: image3,
    alt: "Técnico realizando calibración de termómetros",
    title: "Procedimientos Certificados",
    description: "Nuestros especialistas siguen protocolos bajo norma ISO/IEC 17025 en cada proceso.",
    category: "Procesos"
  },
  {
    image: image4,
    alt: "Set completo de pesas certificadas",
    title: "Patrones Certificados",
    description: "Juegos de pesas desde 1mg hasta 1000kg con certificación internacional.",
    category: "Equipos"
  },
  {
    image: image5,
    alt: "Equipo técnico analizando resultados",
    title: "Expertos en Metrología",
    description: "Nuestro personal cuenta con más de 10 años de experiencia en calibración industrial.",
    category: "Equipo Humano"
  },
  {
    image: image6,
    alt: "Laboratorio de temperatura con cámaras climáticas",
    title: "Control de Variables",
    description: "Cámaras de estabilización para calibración en condiciones controladas.",
    category: "Infraestructura"
  },
  {
    image: image7,
    alt: "Certificados y acreditaciones en la pared",
    title: "Acreditaciones",
    description: "Contamos con certificaciones que avalan nuestra competencia técnica.",
    category: "Reconocimientos"
  },
  {
    image: image8,
    alt: "Vista de equipos de medición dimensional",
    title: "Tecnología de Punta",
    description: "Instrumentos de última generación para mediciones dimensionales exactas.",
    category: "Equipos"
  }
];
---
<section class="py-16 sm:py-24 bg-white">
  <div class="container mx-auto px-5 max-w-7xl">
    {/* Encabezado con texto introductorio */}
    <div class="text-center mb-12 md:mb-16 max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        {title} <span class="text-[#31A4EA]">{subtitle}</span>
      </h2>
      <p class="text-lg text-gray-600 mt-6">
        {introText}
      </p>
    </div>

    {/* Grid Bento mejor distribuido */}
    <div class="grid grid-cols-2 md:grid-cols-6 gap-4 md:gap-5">
      {/* Imagen 1 - Grande horizontal */}
      <div class="relative group col-span-2 row-span-2 rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-all duration-300">
        <Image
          src={galleryItems[0].image}
          alt={galleryItems[0].alt}
          width={800}
          height={600}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-102"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
          <span class="text-[#31A4EA] text-sm font-medium mb-1">{galleryItems[0].category}</span>
          <h3 class="text-xl font-semibold text-white mb-2">{galleryItems[0].title}</h3>
          <p class="text-gray-200 text-sm">{galleryItems[0].description}</p>
        </div>
      </div>

      {/* Imagen 2 - Vertical */}
      <div class="relative group col-span-2 row-span-1 rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-all duration-300">
        <Image
          src={galleryItems[1].image}
          alt={galleryItems[1].alt}
          width={600}
          height={400}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-102"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-4">
          <span class="text-[#31A4EA] text-xs font-medium mb-1">{galleryItems[1].category}</span>
          <h3 class="text-lg font-semibold text-white">{galleryItems[1].title}</h3>
        </div>
      </div>

      {/* Imagen 3 - Pequeña cuadrada */}
      <div class="relative group col-span-1 row-span-1 rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-all duration-300">
        <Image
          src={galleryItems[2].image}
          alt={galleryItems[2].alt}
          width={400}
          height={400}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-102"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>

      {/* Imagen 4 - Pequeña cuadrada */}
      <div class="relative group col-span-1 row-span-1 rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-all duration-300">
        <Image
          src={galleryItems[3].image}
          alt={galleryItems[3].alt}
          width={400}
          height={400}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-102"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>

      {/* Imagen 5 - Horizontal */}
      <div class="relative group col-span-2 row-span-1 rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-all duration-300">
        <Image
          src={galleryItems[4].image}
          alt={galleryItems[4].alt}
          width={800}
          height={400}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-102"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-4">
          <span class="text-[#31A4EA] text-xs font-medium mb-1">{galleryItems[4].category}</span>
          <h3 class="text-lg font-semibold text-white">{galleryItems[4].title}</h3>
        </div>
      </div>

      {/* Imagen 6 - Vertical */}
      <div class="relative group col-span-1 row-span-2 rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-all duration-300">
        <Image
          src={galleryItems[5].image}
          alt={galleryItems[5].alt}
          width={400}
          height={800}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-102"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
          <span class="text-[#31A4EA] text-sm font-medium mb-1">{galleryItems[5].category}</span>
          <h3 class="text-xl font-semibold text-white mb-2">{galleryItems[5].title}</h3>
          <p class="text-gray-200 text-sm">{galleryItems[5].description}</p>
        </div>
      </div>

      {/* Imagen 7 - Pequeña cuadrada */}
      <div class="relative group col-span-1 row-span-1 rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-all duration-300">
        <Image
          src={galleryItems[6].image}
          alt={galleryItems[6].alt}
          width={400}
          height={400}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-102"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>

      {/* Imagen 8 - Pequeña cuadrada */}
      <div class="relative group col-span-1 row-span-1 rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-all duration-300">
        <Image
          src={galleryItems[7].image}
          alt={galleryItems[7].alt}
          width={400}
          height={400}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-102"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>
    </div>

    {/* Texto de cierre */}
    <div class="mt-16 text-center max-w-3xl mx-auto">
      <p class="text-gray-600 mb-6">
        En CYAM combinamos tecnología de punta con procesos certificados para ofrecer servicios de calibración con los más altos estándares de calidad metrológica.
      </p>
    </div>
  </div>
</section>